# Copy this file to .env for local development.
# On Render, these are set automatically by render.yaml (DATABASE_URL, SESSION_SECRET)
# except FRONTEND_ORIGIN, which you set manually in the Render dashboard.

DATABASE_URL=postgres://localhost:5432/spc_unblockers
SESSION_SECRET=replace-with-a-long-random-string
FRONTEND_ORIGIN=http://localhost:5500
NODE_ENV=development
PORT=3000
